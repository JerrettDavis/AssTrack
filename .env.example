# Copy to .env and fill in values
ASSTRACK_API_KEY=change-me
# Optional: separate admin key for destructive maintenance and future enterprise access administration.
# If not set, the operator key also receives the admin role for backward compatibility.
ASSTRACK_ADMIN_API_KEY=
# Optional: separate ingest-only key for device POSTs. If not set, the operator key is used for all requests.
ASSTRACK_INGEST_API_KEY=
# Optional access tier reported by /api/auth/me and /api/system/status: community, professional, or enterprise.
ASSTRACK_ACCESS_TIER=enterprise
Cors__AllowedOrigins__0=https://your-frontend.example.com
# Optional: send webhook POSTs on speed alert and geofence breach events
Webhooks__Url=
Webhooks__TimeoutSeconds=10
Webhooks__MaxRetries=3
Webhooks__RetryBaseDelayMs=1000
Webhooks__RetryMaxDelayMs=30000
# Optional: HMAC-SHA256 signing secret. Set to enable X-AssTrack-Signature-256 header on all outbound webhooks.
Webhooks__SigningSecret=

# Optional: bridge gateway for provider-native webhook/import payloads.
# Start with: docker compose --profile integrations up --build
ASSTRACK_BRIDGE_INGEST_API_KEY=
ASSTRACK_BRIDGE_DRY_RUN=false
ASSTRACK_BRIDGE_GENERIC_ENABLED=false
ASSTRACK_BRIDGE_GENERIC_FEED_ID=00000000-0000-0000-0000-000000000000
ASSTRACK_BRIDGE_GENERIC_SECRET=
ASSTRACK_BRIDGE_MESHTASTIC_ENABLED=false
ASSTRACK_BRIDGE_MESHTASTIC_FEED_ID=00000000-0000-0000-0000-000000000000
ASSTRACK_BRIDGE_MESHTASTIC_SECRET=
ASSTRACK_BRIDGE_OWNTRACKS_ENABLED=false
ASSTRACK_BRIDGE_OWNTRACKS_FEED_ID=00000000-0000-0000-0000-000000000000
ASSTRACK_BRIDGE_OWNTRACKS_SECRET=
ASSTRACK_BRIDGE_TRACCAR_ENABLED=false
ASSTRACK_BRIDGE_TRACCAR_FEED_ID=00000000-0000-0000-0000-000000000000
ASSTRACK_BRIDGE_TRACCAR_SECRET=
