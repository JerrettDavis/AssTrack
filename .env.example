# Copy to .env and fill in values
ASSTRACK_API_KEY=change-me
# Optional: separate ingest-only key for device POSTs. If not set, the operator key is used for all requests.
ASSTRACK_INGEST_API_KEY=
Cors__AllowedOrigins__0=https://your-frontend.example.com
# Optional: send webhook POSTs on speed alert and geofence breach events
Webhooks__Url=
Webhooks__TimeoutSeconds=10
