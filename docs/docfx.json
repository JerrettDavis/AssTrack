{
  "$schema": "https://dotnet.github.io/docfx/schemas/docfx.schema.json",
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml,json}"
        ],
        "src": ".",
        "exclude": [
          "_site/**",
          "docfx.json",
          "openapi/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "openapi/**"
        ],
        "src": "."
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "AssTrack",
      "_appTitle": "AssTrack Docs",
      "_enableSearch": true,
      "pdf": false
    }
  }
}
