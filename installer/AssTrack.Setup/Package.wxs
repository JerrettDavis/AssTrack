<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="AssTrack"
    Manufacturer="Jerrett Davis"
    Version="$(var.ProductVersion)"
    UpgradeCode="2F641F39-3B41-4F27-B10D-0E197A6F3C70"
    Language="1033"
    Scope="perUser">

    <SummaryInformation Description="AssTrack integrated web application" Manufacturer="Jerrett Davis" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of AssTrack is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLROOT" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="AssTrack" />
      </Directory>
    </StandardDirectory>

    <Feature Id="Complete" Title="AssTrack" Level="1">
      <ComponentRef Id="InstallRootCleanup" />
      <ComponentGroupRef Id="AppFiles" />
    </Feature>
  </Package>

  <Fragment>
    <DirectoryRef Id="INSTALLROOT">
      <Component Id="InstallRootCleanup" Directory="INSTALLROOT" Guid="*">
        <RegistryValue Root="HKCU" Key="Software\Jerrett Davis\AssTrack\Installer\Directories" Name="INSTALLROOT" Type="integer" Value="1" KeyPath="yes" />
        <RemoveFolder Id="RemoveInstallRoot" Directory="INSTALLROOT" On="uninstall" />
      </Component>
    </DirectoryRef>
  </Fragment>
</Wix>
